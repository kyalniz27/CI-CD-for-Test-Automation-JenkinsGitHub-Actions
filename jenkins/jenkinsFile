pipeline {
    agent any

    environment {
        DOCKER_HOST = 'tcp://docker:2376'
        DOCKER_CERT_PATH = '/certs/client'
        DOCKER_TLS_VERIFY = '1'
    }

    stages {

        stage('Execute Unit Tests'){
            parallel {
                stage('Backend Unit Tests') {
                    agent {
                        docker {
                            image 'snakee/golang-junit:1.21'
                            reuseNode true
                            args '--network jenkins -v jenkins-docker-certs:/certs/client:ro -e DOCKER_HOST=tcp://docker:2376 -e DOCKER_CERT_PATH=/certs/client -e DOCKER_TLS_VERIFY=1'
                        }
                    }
                    environment {
                        GOCACHE = "${WORKSPACE}/.gocache"
                        GOPATH = "${WORKSPACE}/go"
                    }
                    steps {
                        echo 'Running unit tests for the backend...'
                        dir('bugtracker-backend') {
                            sh 'go test ./... -v 2>&1 | go-junit-report > test-results.xml'
                        }
                    }
                    post {
                        always {
                            echo 'Collecting test results...'
                            junit 'bugtracker-backend/test-results.xml'
                        }
                    }
                }

                stage('Frontend Unit Tests') {
                    agent {
                        docker {
                            image 'node:18'
                            reuseNode true
                            args '--network jenkins -v jenkins-docker-certs:/certs/client:ro -e DOCKER_HOST=tcp://docker:2376 -e DOCKER_CERT_PATH=/certs/client -e DOCKER_TLS_VERIFY=1'
                        }
                    }
                    environment {
                        NODE_ENV = 'test'
                    }
                    steps {
                        echo 'Running unit tests for the frontend...'
                        dir('bugtracker-frontend') {
                            sh 'npm install'
                            sh 'npm test'
                        }
                    }
                    post {
                        always {
                            echo 'Collecting test results...'
                            junit 'bugtracker-frontend/test-results.xml'
                        }
                    }
                }
            }
        }

        stage('Launch application'){
            agent{
                docker {
                    image 'docker:27.5.1'
                    reuseNode true
                    args '--network jenkins -v jenkins-docker-certs:/certs/client:ro -e DOCKER_HOST=tcp://docker:2376 -e DOCKER_CERT_PATH=/certs/client -e DOCKER_TLS_VERIFY=1'
                }
            }
            steps{
                echo 'Testing Docker connectivity...'
                sh 'docker version'
                echo 'Launching the application...'
                sh 'docker compose up --build -d'
                echo 'Checking running containers...'
                sh 'docker ps'
            }
        }
    }

    post {
        always {
            echo 'Cleaning up workspace...'
            cleanWs()
        }
    }
}